import os
import asyncio
from telegram import Update
from telegram.ext import ApplicationBuilder, CommandHandler, MessageHandler, filters, ConversationHandler, ContextTypes
from google.oauth2 import service_account
from googleapiclient.discovery import build
from googleapiclient.http import MediaFileUpload

# Ваш API ключ Telegram
API_KEY = 'ВАШ_ТОКЕН_ТЕЛЕГРАМ'

# Путь к файлу с Google API credentials
CREDENTIALS_FILE = 'credentials.json'

# ID папки или настройка для создания файла в корне
# Можно оставить пустым, чтобы создавать в корне
DRIVE_FOLDER_ID = None  # или вставьте ваш ID папки

# Этапы диалога
ASK_VIDEO_TYPE, GENERATE_VIDEO = range(2)

# Настройка Google Drive API
credentials = service_account.Credentials.from_service_account_file(
    CREDENTIALS_FILE,
    scopes=['https://www.googleapis.com/auth/drive.file']
)
drive_service = build('drive', 'v3', credentials=credentials)

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("Привет! Я помогу создать видео для TikTok. Опиши, какое видео ты хочешь.")
    return ASK_VIDEO_TYPE

async def ask_video_type(update: Update, context: ContextTypes.DEFAULT_TYPE):
    user_text = update.message.text
    context.user_data['prompt'] = user_text
    await update.message.reply_text(f"Понял, создаю видео по запросу: {user_text}\nПодожди немного, я подготовлю видео...")

    # Генерируем видео
    video_path = await generate_video(user_text)
    
    # Загружаем в Google Drive
    file_url = upload_file_to_drive(video_path)
    
    # Отправляем ссылку
    await update.message.reply_text(f"Готово! Вот ваше видео: {file_url}")
    
    # Можно удалить локальный файл, если нужно
    os.remove(video_path)
    
    return ConversationHandler.END

async def generate_video(prompt_text):
    """
    Здесь должна быть логика генерации промпта и видео.
    Пока что создадим тестовое видео или имитируем задержку.
    """
    await asyncio.sleep(3)  # имитация задержки

    # Создайте или скачайте ваше видео сюда и укажите путь
    # Например, скачайте сгенерированное видео или создайте его
    # Для теста создадим пустой файл
    video_filename = 'output_video.mp4'
    with open(video_filename, 'wb') as f:
        f.write(b'\x00\x00\x00\x00')  # замените на ваше видео

    return video_filename

def upload_file_to_drive(file_path):
    file_metadata = {'name': os.path.basename(file_path)}
    if DRIVE_FOLDER_ID:
        file_metadata['parents'] = [DRIVE_FOLDER_ID]
    media = MediaFileUpload(file_path, resumable=True)
    file = drive_service.files().create(body=file_metadata, media_body=media, fields='id').execute()

    # Создаем публичную ссылку
    drive_service.permissions().create(
        fileId=file.get('id'),
        body={'type': 'anyone', 'role': 'reader'}
    ).execute()

    # Получаем публичную ссылку
    file_url = f"https://drive.google.com/uc?id={file.get('id')}&export=download"
    return file_url

async def cancel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("Диалог завершен.")
    return ConversationHandler.END

def main():
    app = ApplicationBuilder().token(API_KEY).build()

    conv_handler = ConversationHandler(
        entry_points=[CommandHandler('start', start)],
        states={
            ASK_VIDEO_TYPE: [MessageHandler(filters.TEXT & ~filters.COMMAND, ask_video_type)],
        },
        fallbacks=[CommandHandler('cancel', cancel)],
    )

    app.add_handler(conv_handler)

    print("Бот запущен")
    app.run_polling()

if __name__ == '__main__':
    main()