{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "sd_xl_base_1.0.safetensors" },
    "_meta": { "title": "Load SDXL checkpoint" }
  },
  "2": {
    "class_type": "EmptyLatentImage",
    "inputs": { "width": 1024, "height": 576, "batch_size": 1 },
    "_meta": { "title": "Empty latent 16:9" }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__POSITIVE_PROMPT__",
      "clip": ["1", 1]
    },
    "_meta": { "title": "Positive prompt" }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__NEGATIVE_PROMPT__",
      "clip": ["1", 1]
    },
    "_meta": { "title": "Negative prompt" }
  },
  "8": {
    "class_type": "IPAdapterModelLoader",
    "inputs": { "ipadapter_file": "ip-adapter-plus_sdxl_vit-h.safetensors" },
    "_meta": { "title": "Load IP-Adapter" }
  },
  "9": {
    "class_type": "CLIPVisionLoader",
    "inputs": { "clip_name": "CLIP-ViT-H-14-laion2B-s32B-b79K.safetensors" },
    "_meta": { "title": "Load CLIP Vision" }
  },
  "10": {
    "class_type": "LoadImage",
    "inputs": { "image": "__REFERENCE_IMAGE__" },
    "_meta": { "title": "Load reference image" }
  },
  "11": {
    "class_type": "PrepImageForClipVision",
    "inputs": {
      "image": ["10", 0],
      "interpolation": "LANCZOS",
      "crop_position": "center",
      "sharpening": 0.0
    },
    "_meta": { "title": "Prep reference for CLIP Vision" }
  },
  "12": {
    "class_type": "IPAdapterAdvanced",
    "inputs": {
      "model": ["1", 0],
      "ipadapter": ["8", 0],
      "image": ["11", 0],
      "clip_vision": ["9", 0],
      "weight": 0.7,
      "weight_type": "linear",
      "combine_embeds": "concat",
      "start_at": 0.0,
      "end_at": 1.0,
      "embeds_scaling": "V only"
    },
    "_meta": { "title": "Apply IP-Adapter" }
  },
  "5": {
    "class_type": "KSamplerAdvanced",
    "inputs": {
      "add_noise": "enable",
      "noise_seed": 0,
      "steps": 28,
      "cfg": 6.5,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "start_at_step": 0,
      "end_at_step": 10000,
      "return_with_leftover_noise": "disable",
      "model": ["12", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "latent_image": ["2", 0]
    },
    "_meta": { "title": "Sample" }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    },
    "_meta": { "title": "Decode" }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["6", 0],
      "filename_prefix": "scene_image"
    },
    "_meta": { "title": "Save scene image" }
  }
}
