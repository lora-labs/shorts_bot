{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "ltx-2.3-22b-distilled-fp8.safetensors" },
    "_meta": { "title": "Load LTX checkpoint" }
  },
  "2": {
    "class_type": "LTXAVTextEncoderLoader",
    "inputs": {
      "text_encoder": "gemma_3_12B_it_fp4_mixed.safetensors",
      "ckpt_name": "ltx-2.3-22b-distilled-fp8.safetensors",
      "device": "default"
    },
    "_meta": { "title": "LTX text encoder" }
  },
  "3": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {
      "model": ["1", 0],
      "lora_name": "ltx-2.3-22b-distilled-lora-384.safetensors",
      "strength_model": 1.0
    },
    "_meta": { "title": "Apply LTX distilled LoRA" }
  },
  "4": {
    "class_type": "LoadImage",
    "inputs": { "image": "__INPUT_IMAGE__" },
    "_meta": { "title": "Load keyframe image" }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__VIDEO_POSITIVE__",
      "clip": ["2", 0]
    },
    "_meta": { "title": "Video positive prompt" }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__VIDEO_NEGATIVE__",
      "clip": ["2", 0]
    },
    "_meta": { "title": "Video negative prompt" }
  },
  "7": {
    "class_type": "LTXVPreprocess",
    "inputs": {
      "image": ["4", 0],
      "img_compression": 4
    },
    "_meta": { "title": "Preprocess keyframe" }
  },
  "8": {
    "class_type": "EmptyLTXVLatentVideo",
    "inputs": {
      "width": 544,
      "height": 960,
      "length": 121,
      "batch_size": 1
    },
    "_meta": { "title": "Empty video latent" }
  },
  "9": {
    "class_type": "LTXVImgToVideoConditionOnly",
    "inputs": {
      "vae": ["1", 2],
      "image": ["7", 0],
      "latent": ["8", 0],
      "strength": 1.0,
      "bypass": false
    },
    "_meta": { "title": "LTX image to video condition" }
  },
  "10": {
    "class_type": "LTXVAudioVAELoader",
    "inputs": { "ckpt_name": "ltx-2.3-22b-distilled-fp8.safetensors" },
    "_meta": { "title": "Load audio VAE" }
  },
  "11": {
    "class_type": "LTXVEmptyLatentAudio",
    "inputs": {
      "frames_number": 121,
      "frame_rate": 25,
      "batch_size": 1,
      "audio_vae": ["10", 0]
    },
    "_meta": { "title": "Empty audio latent" }
  },
  "12": {
    "class_type": "LTXVConcatAVLatent",
    "inputs": {
      "video_latent": ["9", 0],
      "audio_latent": ["11", 0]
    },
    "_meta": { "title": "Concat AV latent" }
  },
  "13": {
    "class_type": "LTXVConditioning",
    "inputs": {
      "positive": ["5", 0],
      "negative": ["6", 0],
      "frame_rate": 25.0
    },
    "_meta": { "title": "LTX conditioning" }
  },
  "14": {
    "class_type": "LTXVScheduler",
    "inputs": {
      "steps": 15,
      "max_shift": 2.05,
      "base_shift": 0.95,
      "stretch": true,
      "terminal": 0.1,
      "latent": ["12", 0]
    },
    "_meta": { "title": "LTX scheduler" }
  },
  "15": {
    "class_type": "KSamplerSelect",
    "inputs": { "sampler_name": "euler" },
    "_meta": { "title": "Sampler select" }
  },
  "16": {
    "class_type": "RandomNoise",
    "inputs": { "noise_seed": 0 },
    "_meta": { "title": "Random noise" }
  },
  "17": {
    "class_type": "CFGGuider",
    "inputs": {
      "model": ["3", 0],
      "positive": ["13", 0],
      "negative": ["13", 1],
      "cfg": 1.0
    },
    "_meta": { "title": "CFG guider" }
  },
  "18": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise": ["16", 0],
      "guider": ["17", 0],
      "sampler": ["15", 0],
      "sigmas": ["14", 0],
      "latent_image": ["12", 0]
    },
    "_meta": { "title": "Sample AV latent" }
  },
  "19": {
    "class_type": "LTXVSeparateAVLatent",
    "inputs": {
      "av_latent": ["18", 0]
    },
    "_meta": { "title": "Separate AV latent" }
  },
  "20": {
    "class_type": "LTXVTiledVAEDecode",
    "inputs": {
      "vae": ["1", 2],
      "latents": ["19", 0],
      "horizontal_tiles": 2,
      "vertical_tiles": 2,
      "overlap": 2,
      "last_frame_fix": false
    },
    "_meta": { "title": "Decode video latent" }
  },
  "21": {
    "class_type": "CreateVideo",
    "inputs": {
      "images": ["20", 0],
      "fps": 25.0
    },
    "_meta": { "title": "Create video from frames" }
  },
  "22": {
    "class_type": "SaveVideo",
    "inputs": {
      "video": ["21", 0],
      "filename_prefix": "scene_video",
      "format": "mp4",
      "codec": "h264"
    },
    "_meta": { "title": "Save scene video" }
  }
}
