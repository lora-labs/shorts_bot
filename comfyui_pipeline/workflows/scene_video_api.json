{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "ltx-2.3-22b-distilled-1.1.safetensors" },
    "_meta": { "title": "Load LTX checkpoint" }
  },
  "2": {
    "class_type": "LTXAVTextEncoderLoader",
    "inputs": {
      "text_encoder": "comfy_gemma_3_12B_it.safetensors",
      "ckpt_name": "ltx-2.3-22b-distilled-1.1.safetensors",
      "device": "default"
    },
    "_meta": { "title": "LTX text encoder" }
  },
  "3": {
    "class_type": "LoraLoaderModelOnly",
    "inputs": {
      "model": ["1", 0],
      "lora_name": "ltx-2.3-22b-distilled-lora-384-1.1.safetensors",
      "strength_model": 1.0
    },
    "_meta": { "title": "Apply LTX distilled LoRA" }
  },
  "4": {
    "class_type": "LoadImage",
    "inputs": { "image": "__INPUT_IMAGE__" },
    "_meta": { "title": "Load keyframe image" }
  },
  "5": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__VIDEO_POSITIVE__",
      "clip": ["2", 0]
    },
    "_meta": { "title": "Video positive prompt" }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "text": "__VIDEO_NEGATIVE__",
      "clip": ["2", 0]
    },
    "_meta": { "title": "Video negative prompt" }
  },
  "7": {
    "class_type": "LTXVImgToVideo",
    "inputs": {
      "positive": ["5", 0],
      "negative": ["6", 0],
      "vae": ["1", 2],
      "image": ["4", 0],
      "width": 960,
      "height": 544,
      "length": 121,
      "batch_size": 1,
      "strength": 1.0
    },
    "_meta": { "title": "LTX img-to-video" }
  },
  "8": {
    "class_type": "LTXVConditioning",
    "inputs": {
      "positive": ["7", 0],
      "negative": ["7", 1],
      "frame_rate": 25.0
    },
    "_meta": { "title": "LTX conditioning" }
  },
  "9": {
    "class_type": "LTXVScheduler",
    "inputs": {
      "steps": 15,
      "max_shift": 2.05,
      "base_shift": 0.95,
      "stretch": true,
      "terminal": 0.1,
      "latent": ["7", 2]
    },
    "_meta": { "title": "LTX scheduler" }
  },
  "10": {
    "class_type": "KSamplerSelect",
    "inputs": { "sampler_name": "euler" },
    "_meta": { "title": "Sampler select" }
  },
  "11": {
    "class_type": "RandomNoise",
    "inputs": { "noise_seed": 0 },
    "_meta": { "title": "Random noise" }
  },
  "12": {
    "class_type": "CFGGuider",
    "inputs": {
      "model": ["3", 0],
      "positive": ["8", 0],
      "negative": ["8", 1],
      "cfg": 1.0
    },
    "_meta": { "title": "CFG guider" }
  },
  "13": {
    "class_type": "SamplerCustomAdvanced",
    "inputs": {
      "noise": ["11", 0],
      "guider": ["12", 0],
      "sampler": ["10", 0],
      "sigmas": ["9", 0],
      "latent_image": ["7", 2]
    },
    "_meta": { "title": "Sample video latent" }
  },
  "14": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["13", 0],
      "vae": ["1", 2]
    },
    "_meta": { "title": "Decode frames" }
  },
  "15": {
    "class_type": "CreateVideo",
    "inputs": {
      "images": ["14", 0],
      "fps": 25.0
    },
    "_meta": { "title": "Create video from frames" }
  },
  "16": {
    "class_type": "SaveVideo",
    "inputs": {
      "video": ["15", 0],
      "filename_prefix": "scene_video",
      "format": "mp4",
      "codec": "h264"
    },
    "_meta": { "title": "Save scene video" }
  }
}
